<h2 class="mb-6 text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Recent Posts</h2>

<% @posts.each do |post| %>
  <article class="mb-8 border-b border-slate-200 pb-5">
    <h3 class="text-lg font-semibold text-slate-900 sm:text-xl">
      <%= link_to post.post_title, post_path(post), class: "text-brand-700 no-underline hover:text-brand-500" %>
    </h3>
    <div class="mt-1 text-sm text-slate-500">
      <%= post.post_date.strftime("%B %d, %Y") %>
    </div>
    <div class="mt-3 leading-7 text-slate-700">
      <%= truncate(strip_tags(post.post_content), length: 200) %>
    </div>
  </article>
<% end %>
