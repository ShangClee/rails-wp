<h2>Recent Posts</h2>

<% @posts.each do |post| %>
  <article style="margin-bottom: 30px; border-bottom: 1px solid #ddd; padding-bottom: 20px;">
    <h3><%= link_to post.post_title, post_path(post) %></h3>
    <div style="color: #666; font-size: 0.9em;">
      <%= post.post_date.strftime("%B %d, %Y") %>
    </div>
    <div style="margin-top: 10px;">
      <%= truncate(strip_tags(post.post_content), length: 200) %>
    </div>
  </article>
<% end %>
